{
  "name": "wickra-compile",
  "version": "0.1.0",
  "description": "Compile a Wickra strategy spec into a standalone deployable (WASM, binary, or no_std) with a deterministic manifest. Node bindings powered by Rust.",
  "author": "kingchenc <support@wickra.org>",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT OR Apache-2.0",
  "keywords": ["trading", "strategy", "compiler", "wasm", "codegen", "rust"],
  "repository": { "type": "git", "url": "https://github.com/wickra-lib/wickra-compile" },
  "bugs": { "url": "https://github.com/wickra-lib/wickra-compile/issues" },
  "homepage": "https://github.com/wickra-lib/wickra-compile",
  "files": ["index.js", "index.d.ts", "npm", "*.node"],
  "napi": {
    "name": "wickra-compile",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "x86_64-apple-darwin",
        "aarch64-apple-darwin",
        "x86_64-pc-windows-msvc",
        "aarch64-pc-windows-msvc"
      ]
    }
  },
  "engines": { "node": ">= 22" },
  "optionalDependencies": {
    "wickra-compile-linux-x64-gnu": "0.1.0",
    "wickra-compile-linux-arm64-gnu": "0.1.0",
    "wickra-compile-darwin-x64": "0.1.0",
    "wickra-compile-darwin-arm64": "0.1.0",
    "wickra-compile-win32-x64-msvc": "0.1.0",
    "wickra-compile-win32-arm64-msvc": "0.1.0"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "artifacts": "napi artifacts",
    "version": "napi version",
    "test": "node --test"
  },
  "devDependencies": { "@napi-rs/cli": "^3.7.2" }
}
